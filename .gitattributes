# Git LFS tracking for decompiled source directories
yodaos/DECOMPILED/** filter=lfs diff=lfs merge=lfs -text
yodaos/DECOMPILED-APPS/** filter=lfs diff=lfs merge=lfs -text
cxr-m/decompiled/** filter=lfs diff=lfs merge=lfs -text
cxr-l/decompiled/** filter=lfs diff=lfs merge=lfs -text
cxr-s/decompiled/** filter=lfs diff=lfs merge=lfs -text
# Compiled firmware and system dumps
yodaos/COMPILED*/** filter=lfs diff=lfs merge=lfs -text
yodaos/DUMPED/** filter=lfs diff=lfs merge=lfs -text

# Binary firmware files
*.bin filter=lfs diff=lfs merge=lfs -text
*.fw filter=lfs diff=lfs merge=lfs -text
*.img filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
# Normalize line endings for markdown
*.md text eol=lf
